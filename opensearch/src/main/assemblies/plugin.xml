<?xml version="1.0"?>
<assembly>
    <id>plugin</id>
    <formats>
        <format>zip</format>
    </formats>
    <includeBaseDirectory>false</includeBaseDirectory>
    <dependencySets>
        <dependencySet>
            <outputDirectory>/</outputDirectory>
            <useProjectArtifact>true</useProjectArtifact>
            <!-- bundle only what OpenSearch core does NOT provide; opensearch + lucene-core +
                 lucene-analysis-common are provided at runtime and must not be bundled (JarHell) -->
            <includes>
                <include>io.github.radeno:opensearch-analysis-opennlp-lemmatizer</include>
                <include>io.github.radeno:opennlp-lemmatizer-core</include>
                <include>org.apache.lucene:lucene-analysis-opennlp</include>
                <include>org.apache.opennlp:opennlp-tools</include>
                <include>org.slf4j:slf4j-api</include>
            </includes>
        </dependencySet>
    </dependencySets>
    <files>
        <file>
            <source>plugin-descriptor.properties</source>
            <outputDirectory>/</outputDirectory>
            <filtered>true</filtered>
        </file>
    </files>
</assembly>
